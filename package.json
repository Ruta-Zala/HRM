{
  "name": "exhibyte-hrm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n web,agent -c blue,magenta \"next dev\" \"npm run dev:agent\"",
    "dev:web": "next dev",
    "dev:agent": "langgraphjs dev --port 2024 --host 127.0.0.1 --no-browser",
    "start:agent": "langgraphjs dev --port 2024 --host 127.0.0.1 --no-browser",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "lint:staged": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,css,md,mdx,yml,yaml}": "prettier --write",
    "*.{js,jsx,ts,tsx,mjs}": "eslint --max-warnings 0"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/langgraph-cli": "^1.2.3",
    "@langchain/langgraph-sdk": "^1.9.9",
    "@langchain/react": "^1.0.10",
    "@reduxjs/toolkit": "^2.12.0",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "langchain": "^1.4.2",
    "lucide-react": "^1.14.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nodemon": "^3.1.14",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-redux": "^9.3.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
